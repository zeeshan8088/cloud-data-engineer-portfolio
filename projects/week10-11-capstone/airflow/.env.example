# ============================================================
# RetailFlow — Airflow Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# Never commit .env to git (it's in .gitignore).
# ============================================================

# ── GCP Project ───────────────────────────────────────────────
GCP_PROJECT=intricate-ward-459513-e1
GCP_REGION=asia-south1
BQ_DATASET_META=retailflow_metadata

# ── GCP Authentication ────────────────────────────────────────
# Path to your service account JSON key file (absolute path).
# For local dev you can also use ADC:
#   gcloud auth application-default login
# and set GOOGLE_APPLICATION_CREDENTIALS to the ADC path.
GOOGLE_APPLICATION_CREDENTIALS=~/.config/gcloud/application_default_credentials.json

# ── Airflow ───────────────────────────────────────────────────
# UID of the airflow user (run: id -u  in WSL/Linux)
# On Windows with Docker Desktop, use 50000
AIRFLOW_UID=50000

# Fernet key for encrypting connection passwords
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here

# ── RetailFlow paths ──────────────────────────────────────────
# These are set automatically by docker-compose.yml
# Override only if you change the project structure.
RETAILFLOW_HOME=/opt/airflow/retailflow
DBT_BIN=/home/airflow/.local/bin/dbt
